{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Launch Extension",
			"type": "extensionHost",
			"request": "launch",
			"runtimeExecutable": "${execPath}",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}",
				"${workspaceFolder}/../../bmozaffa/postgresql-vulnerability-example"
			],
			"sourceMaps": true,
			"outFiles": [
				"${workspaceFolder}/dist/*.js"
			],
			"preLaunchTask": "npm: webpack-dev",
		},
    {
